# ─── Server Configuration ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,https://snist.cloudcommunityclub.tech,https://cloudcommunityclub-c3.vercel.app,https://cloudcommunityclub-c3-*.vercel.app

# ─── Database Configuration ────────────────────────────────────────────────────
# Connection string for MongoDB Atlas or local MongoDB instance
MONGO_URI=mongodb://localhost:27017/C3

# ─── Security & Authentication ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=generate_a_random_64_character_hex_string_here
ADMIN_PASSWORD=change_this_to_a_strong_admin_password

# ─── File Storage Configuration ────────────────────────────────────────────────
# Optional: Absolute path where uploaded files should be saved.
# Defaults to "./uploads" relative to c3_backend project root if left unset or commented out.
# UPLOAD_PATH=/var/www/uploads

# Optional: Cloudflare R2 configuration for fallback when retrieving legacy screenshots
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=c3-uploads

# ─── Email & OAuth Configuration ───────────────────────────────────────────────
EMAIL_USER=c3.snist@gmail.com
CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
CLIENT_SECRET=your_google_oauth_client_secret
REFRESH_TOKEN=your_google_oauth_refresh_token
OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground

# Optional: Direct SMTP Credentials (if not using OAuth)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=c3.snist@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=Cloud Community Club (C³) <c3.snist@gmail.com>

# ─── Community Social Links ────────────────────────────────────────────────────
InstragramLink=https://www.instagram.com/c3.snist/
WhatsappLink=https://chat.whatsapp.com/I0Z9iJ4O9veByzx20AofGY
