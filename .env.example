# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/c3

# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=8000

# ─── SMTP Configuration (for submission confirmation emails) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Cloud Community Club (C³) <your_email@gmail.com>

# ─── Google OAuth2 (for Gmail API — used for registration welcome emails) ────
# Generate credentials at: https://console.cloud.google.com/
CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
CLIENT_SECRET=your_google_oauth_client_secret
REFRESH_TOKEN=your_google_oauth_refresh_token
OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground

# ─── Cloudflare R2 (optional — for serving old R2-hosted screenshots) ──────────
# If not configured, old R2 screenshots show "not available" in the admin dashboard.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=c3-uploads

# ─── API Security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" ──
API_KEY=generate_a_random_64_character_hex_string_here

# ─── CORS — comma-separated list of allowed origins ───────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://snist.cloudcommunityclub.tech,https://cloudcommunityclub-c3.vercel.app

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_this_to_a_strong_admin_password
